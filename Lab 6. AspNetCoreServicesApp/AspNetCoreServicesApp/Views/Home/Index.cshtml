@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <div class="mt-4">
        <h3>Calculator Operations</h3>
        <a class="btn btn-primary m-2" asp-controller="Calculator" asp-action="AddTwoDecimals">Add</a>
        <a class="btn btn-primary m-2" asp-controller="Calculator" asp-action="SubtractTwoDecimals">Subtract</a>
        <a class="btn btn-primary m-2" asp-controller="Calculator" asp-action="MultiplyTwoDecimals">Multiply</a>
        <a class="btn btn-primary m-2" asp-controller="Calculator" asp-action="DivideTwoDecimals">Divide</a>
    </div>
</div>
